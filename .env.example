# Run: npm run setup-admin  (writes CMS_SECRET, quoted ADMIN_PASSWORD_BCRYPT, ADMIN_LOGIN_PLAIN for local dev)
# Restart npm run dev after. Never commit .env. Do not set ADMIN_LOGIN_PLAIN on production hosts.

ADMIN_PASSWORD_BCRYPT=

CMS_SECRET=

# Development only — same password setup-admin prints; login works even if bcrypt env parsing fails
ADMIN_LOGIN_PLAIN=

# Optional: override where JSON content lives (default: ./data)
# DATA_DIR=

# Optional: where extracted SCORM packages live (default: ./scorm-packages)
# Each package is a folder named by id, containing imsmanifest.xml + assets.
# SCORM_PACKAGES_PATH=

# Contact form (optional — leave empty to hide or disable sending)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_TO_EMAIL=
# SMTP_FROM=
